#!/usr/bin/env bash
set -euo pipefail

DOCKER_DIR="${DOCKER_DIR:-/opt/docker}"
HOSTNAME_SHORT="$(hostname -s)"
HOST_FILE="${DOCKER_DIR}/hosts/${HOSTNAME_SHORT}.yaml"
BASE_FILE="${DOCKER_DIR}/docker-compose.yml"
ENV_FILE="${DOCKER_DIR}/.env"

REPO_SYNC_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/sync-docker-config"

if [ -x "$REPO_SYNC_SCRIPT" ]; then
  "$REPO_SYNC_SCRIPT"
fi

if [ ! -d "$DOCKER_DIR" ]; then
  echo "not good: missing $DOCKER_DIR"
  exit 1
fi

if [ ! -f "$BASE_FILE" ]; then
  echo "not good: missing $BASE_FILE"
  exit 1
fi

if [ ! -f "$HOST_FILE" ]; then
  echo "not good: missing $HOST_FILE"
  exit 1
fi

if [ ! -f "$ENV_FILE" ]; then
  echo "not good: missing $ENV_FILE"
  exit 1
fi

cd "$DOCKER_DIR"

echo "Deploying host: $HOSTNAME_SHORT"

docker compose \
  --env-file "$ENV_FILE" \
  -f "$BASE_FILE" \
  -f "$HOST_FILE" \
  config >/dev/null

docker compose \
  --env-file "$ENV_FILE" \
  -f "$BASE_FILE" \
  -f "$HOST_FILE" \
  up -d

echo "good"
