#!/usr/bin/env bash
set -euo pipefail

# Stage/apply UFW baseline for jellyberry only.
# Dry-run by default. Use --apply locally on jellyberry after Tailscale SSH and LAN SSH are open.

apply=false
if [[ "${1:-}" == "--apply" ]]; then
  apply=true
elif [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'USAGE'
Usage:
  scripts/firewall/apply-jellyberry-ufw          # print intended commands
  scripts/firewall/apply-jellyberry-ufw --apply  # apply with sudo

Preconditions:
  - Run only on jellyberry.
  - Tailscale SSH verified from an independent operator session.
  - LAN SSH verified from 192.168.1.0/24.
  - Be ready to run: sudo ufw disable
USAGE
  exit 0
elif [[ $# -gt 0 ]]; then
  echo "error: unknown argument: $1" >&2
  exit 2
fi

host=$(hostname -s)
if [[ "$host" != "jellyberry" ]]; then
  echo "error: this script is for jellyberry only; current host=$host" >&2
  exit 1
fi

run() {
  printf '+ %q' "$1"
  shift || true
  printf ' %q' "$@"
  printf '\n'
  if [[ "$apply" == true ]]; then
    "$@"
  fi
}

run_sudo() {
  printf '+ sudo'
  printf ' %q' "$@"
  printf '\n'
  if [[ "$apply" == true ]]; then
    sudo "$@"
  fi
}

cat <<'NOTE'
# jellyberry firewall intent
# Keep two management paths:
#   - LAN SSH: 192.168.1.0/24 -> tcp/22
#   - Tailnet: tailscale0 all inbound
# Keep LAN/Tailnet app access:
#   - 8787 Portfolio Mission Control
#   - 8791 SC-401 Study Hub
#   - 8792 Image Pastebin
# Restrict monitoring/agent ports where UFW can enforce host-input traffic:
#   - 9100 node_exporter from jellybase only
#   - 12345 Alloy metrics from jellybase only
#   - 7007 Dozzle agent from jellyhome only
#
# Docker note:
# Docker-published ports can bypass plain UFW via Docker iptables/NAT paths.
# This baseline is still useful for host-input policy, but Docker-published
# service restrictions must be verified separately with DOCKER-USER rules or
# service bind-address changes before claiming full port hardening.
NOTE

if [[ "$apply" == true ]]; then
  sudo -v
fi

run_sudo ufw --force reset
run_sudo ufw default deny incoming
run_sudo ufw default allow outgoing

# Management backdoors.
run_sudo ufw allow in on tailscale0 comment 'Tailnet emergency/operator access'
run_sudo ufw allow from 192.168.1.0/24 to any port 22 proto tcp comment 'LAN SSH admin'

# LAN/Tailnet app access.
for port in 8787 8791 8792; do
  run_sudo ufw allow from 192.168.1.0/24 to any port "$port" proto tcp comment "LAN app ${port}"
  run_sudo ufw allow in on tailscale0 to any port "$port" proto tcp comment "Tailnet app ${port}"
done

# Service-peer / monitoring access.
run_sudo ufw allow from 192.168.1.2 to any port 9100 proto tcp comment 'Prometheus scrape node_exporter from jellybase'
run_sudo ufw allow from 192.168.1.2 to any port 12345 proto tcp comment 'Prometheus scrape Alloy from jellybase'
run_sudo ufw allow from 192.168.1.1 to any port 7007 proto tcp comment 'Dozzle UI to jellyberry agent from jellyhome'

run_sudo ufw --force enable
run_sudo ufw status verbose

cat <<'VERIFY'

# Verify immediately from another shell:
#   LAN:       ssh jellybot@192.168.1.159 'hostname -s; sudo ufw status verbose'
#   Tailnet:   tailscale ssh jellybot@jellyberry 'hostname -s; sudo ufw status verbose'
#   Apps:      curl -fsS http://192.168.1.159:8787/ >/dev/null && echo 8787-ok
#              curl -fsS http://192.168.1.159:8791/ >/dev/null && echo 8791-ok
#              curl -fsS http://192.168.1.159:8792/ >/dev/null && echo 8792-ok
#   Prometheus: check jellyberry up/node_exporter/alloy targets stay green.
# Rollback if needed:
#   sudo ufw disable
VERIFY
