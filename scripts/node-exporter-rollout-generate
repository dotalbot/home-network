def load_inventory(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as f:
        data = yaml.safe_load(f) or {}
    if not isinstance(data, dict):
        fail("inventory root must be a mapping")
    return data


def monitored_hosts(data: dict[str, Any]) -> dict[str, dict[str, Any]]:
    defaults_root = data.get("monitoring_defaults") or {}
    if not isinstance(defaults_root, dict):
        fail("monitoring_defaults must be a mapping")
    defaults = defaults_root.get("node_exporter") or {}
    if not isinstance(defaults, dict):
        fail("monitoring_defaults.node_exporter must be a mapping")
    hosts = data.get("hosts") or {}
    if not isinstance(hosts, dict):
        fail("hosts must be a mapping")
    allowed_scrapers_raw = defaults.get("allowed_scrapers") or []
    if not isinstance(allowed_scrapers_raw, list) or not allowed_scrapers_raw:
        fail("monitoring_defaults.node_exporter.allowed_scrapers must be a non-empty list")
    allowed_scrapers: list[dict[str, str]] = []
    for idx, item in enumerate(allowed_scrapers_raw):
        if not isinstance(item, dict):
            fail(f"monitoring_defaults.node_exporter.allowed_scrapers[{idx}] must be a mapping")
        scraper_host = validate_host_name(str(item.get("host") or ""), f"monitoring_defaults.node_exporter.allowed_scrapers[{idx}].host")
        scraper_cfg = hosts.get(scraper_host)
        if not isinstance(scraper_cfg, dict):
            fail(f"allowed scraper host {scraper_host} is not defined in hosts")
        scraper_ip = validate_ip(scraper_cfg.get("lan_ip"), f"hosts.{scraper_host}.lan_ip")
        allowed_scrapers.append({"host": scraper_host, "ip": scraper_ip})
    result: dict[str, dict[str, Any]] = {}
    for raw_host, raw_cfg in sorted(hosts.items()):
        host = validate_host_name(str(raw_host), "hosts key")
        if not isinstance(raw_cfg, dict):
            print(f"warning: skipping {host}: host config is not a mapping", file=sys.stderr)
            continue
        roles = raw_cfg.get("roles") or []
        if not isinstance(roles, list):
            fail(f"hosts.{host}.roles must be a list")
        monitoring = raw_cfg.get("monitoring") or {}
        if not isinstance(monitoring, dict):
            fail(f"hosts.{host}.monitoring must be a mapping")
        override = monitoring.get("node_exporter") or {}
        if not isinstance(override, dict):
            fail(f"hosts.{host}.monitoring.node_exporter must be a mapping")
        cfg = merge_node_exporter(defaults, override)
        enabled = cfg.get("enabled") is True
        has_role = "node-exporter-client" in roles
        if enabled and not has_role:
            fail(f"hosts.{host} enables node_exporter without node-exporter-client role")
        if not (enabled and has_role):
            continue
        cfg["host"] = host
        if raw_cfg.get("lan_ip") is None:
            fail(f"hosts.{host}.lan_ip is required for node_exporter firewall allowlisting")
        cfg["lan_ip"] = validate_ip(raw_cfg.get("lan_ip"), f"hosts.{host}.lan_ip")
        cfg["allowed_scrapers"] = allowed_scrapers
        cfg["scrape_host"] = validate_host_name(str(cfg.get("scrape_host") or host), f"hosts.{host}.monitoring.node_exporter.scrape_host")
        cfg["scrape_port"] = validate_port(cfg.get("scrape_port"), f"hosts.{host}.monitoring.node_exporter.scrape_port")
        scheme = cfg.get("scrape_scheme")
        if not isinstance(scheme, str) or not SAFE_SCHEME_RE.fullmatch(scheme):
            fail(f"hosts.{host}.monitoring.node_exporter.scrape_scheme must be http or https")
        cfg["textfile_collector_dir"] = validate_abs_path(str(cfg.get("textfile_collector_dir")), f"hosts.{host}.monitoring.node_exporter.textfile_collector_dir")
        if cfg.get("disk_health") != "best-effort":
            fail(f"hosts.{host}.monitoring.node_exporter.disk_health must be best-effort")
        devices = cfg.get("disk_devices")
        if devices != ["auto"]:
            fail(f"hosts.{host}.monitoring.node_exporter.disk_devices must currently be [auto]")
        if "pi" in roles and cfg.get("pi_early_warning") is not True:
            fail(f"hosts.{host} is a Pi node_exporter client but pi_early_warning is not true")
        result[host] = cfg
    return result


def write_stage(path: Path, content: str) -> None:
    path.write_text(content, encoding="utf-8")
    path.chmod(0o755)


def render_readme(out_dir: Path, host: str, cfg: dict[str, Any]) -> str:
    return f"""# node_exporter rollout for {host}

Generated by `scripts/node-exporter-rollout-generate`.

Run these manually on `{host}` as the operator, reviewing each step first:

```bash
cd {out_dir}
sudo ./stage-00-preflight.sh
sudo ./stage-01-install-packages.sh
sudo ./stage-02-configure-node-exporter.sh
sudo ./stage-03-install-disk-health-probe.sh
sudo ./stage-04-enable-disk-health-timer.sh
sudo ./stage-05-verify-local-metrics.sh
sudo ./stage-06-prometheus-target-note.sh
sudo ./stage-07-configure-access-control.sh
sudo ./stage-08-install-log-signal-probe.sh
sudo ./stage-09-enable-log-signal-timer.sh
sudo ./stage-10-verify-log-signal-metrics.sh
```

Overwrite safety flags, only after reviewing existing files:

```bash
sudo ALLOW_OVERWRITE_DISK_HEALTH_PROBE=1 ./stage-03-install-disk-health-probe.sh
sudo ALLOW_OVERWRITE_DISK_HEALTH_TIMER=1 ./stage-04-enable-disk-health-timer.sh
sudo ALLOW_OVERWRITE_LOG_SIGNAL_PROBE=1 ./stage-08-install-log-signal-probe.sh
sudo ALLOW_OVERWRITE_LOG_SIGNAL_TIMER=1 ./stage-09-enable-log-signal-timer.sh
```

Expected local metrics endpoint:

```text
{cfg['scrape_scheme']}://{cfg['scrape_host']}:{cfg['scrape_port']}/metrics
```

Security note: TCP 9100 access-control hardening is handled by optional stage 07. It applies UFW rules only when UFW is already active; otherwise it prints the exact recommended allow/deny policy and does not enable or rewrite the host firewall.
"""


def generate(inventory: Path) -> list[Path]:
    data = load_inventory(inventory)
    hosts = monitored_hosts(data)
    if not hosts:
        fail("no enabled node-exporter-client hosts found")
    outputs: list[Path] = []
    scrape_targets = [f"{cfg['scrape_host']}:{cfg['scrape_port']}" for cfg in hosts.values()]
    for host, cfg in hosts.items():
        out_dir = Path("/tmp") / f"node-exporter-rollout-{host}"
        if out_dir.exists():
            shutil.rmtree(out_dir)
        out_dir.mkdir(parents=True, exist_ok=True)
        for name, content in stages(host, cfg, scrape_targets).items():
            write_stage(out_dir / name, content)
        (out_dir / "README.md").write_text(render_readme(out_dir, host, cfg), encoding="utf-8")
        outputs.append(out_dir)
    return outputs


def main(argv: list[str]) -> int:
    inventory = Path(argv[1]) if len(argv) > 1 else DEFAULT_INVENTORY
    outputs = generate(inventory)
    for path in outputs:
        print(path)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except ValueError as exc:
        print(f"not good: {exc}", file=sys.stderr)
        raise SystemExit(1)
