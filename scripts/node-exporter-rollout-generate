        "stage-07-configure-access-control.sh": base + f'''
echo "Configure node_exporter TCP ${{SCRAPE_PORT}} access control for $EXPECTED_HOST"
ALLOWED_SCRAPER_HOSTS=({allowed_host_array})
ALLOWED_SCRAPER_IPS=({allowed_ip_array})

echo "Approved Prometheus scraper sources:"
for idx in "${{!ALLOWED_SCRAPER_HOSTS[@]}}"; do
  echo "  - ${{ALLOWED_SCRAPER_HOSTS[$idx]}} (${{ALLOWED_SCRAPER_IPS[$idx]}})"
done

curl -fsS "http://127.0.0.1:${{SCRAPE_PORT}}/metrics" | grep -E '^(node_exporter_build_info|node_uname_info|node_filesystem_size_bytes)' >/dev/null

print_recommended_rules() {{
  echo "Recommended UFW policy for $EXPECTED_HOST, review before applying:"
  for ip in "${{ALLOWED_SCRAPER_IPS[@]}}"; do
    echo "sudo ufw allow from $ip to any port $SCRAPE_PORT proto tcp comment 'home-network Prometheus scrape'"
  done
  if [ "$EXPECTED_HOST" = "jellybase" ]; then
    echo "# jellybase Prometheus runs in Docker; allow local Docker bridge subnets if the scrape target remains host.docker.internal:9100:"
    ip -o -4 addr show | awk '$2 ~ /^(docker0|br-)/ {{print $4}}' | sort -u | while read -r cidr; do
      [ -n "$cidr" ] && echo "sudo ufw allow from $cidr to any port $SCRAPE_PORT proto tcp comment 'home-network local Docker Prometheus scrape'"
    done
  fi
  echo "sudo ufw deny $SCRAPE_PORT/tcp comment 'home-network deny non-scraper node_exporter'"
}}

if ! command -v ufw >/dev/null 2>&1; then
  echo "not applied: ufw is not installed; use equivalent nftables/iptables rules: allow approved scraper IPs, then deny TCP $SCRAPE_PORT."
  print_recommended_rules
  exit 0
fi

status_line="$(ufw status | sed -n '1p')"
echo "$status_line"
if ! printf '%s\n' "$status_line" | grep -qi '^Status: active'; then
  echo "not applied: UFW is installed but inactive. This stage does not enable or rewrite firewall policy automatically."
  print_recommended_rules
  exit 0
fi

insert_pos=1
for ip in "${{ALLOWED_SCRAPER_IPS[@]}}"; do
  ufw insert "$insert_pos" allow from "$ip" to any port "$SCRAPE_PORT" proto tcp comment 'home-network Prometheus scrape'
  insert_pos=$((insert_pos + 1))
done

if [ "$EXPECTED_HOST" = "jellybase" ]; then
  while read -r cidr; do
    if [ -n "$cidr" ]; then
      ufw insert "$insert_pos" allow from "$cidr" to any port "$SCRAPE_PORT" proto tcp comment 'home-network local Docker Prometheus scrape'
      insert_pos=$((insert_pos + 1))
    fi
  done < <(ip -o -4 addr show | awk '$2 ~ /^(docker0|br-)/ {{print $4}}' | sort -u)
fi

ufw insert "$insert_pos" deny "$SCRAPE_PORT/tcp" comment 'home-network deny non-scraper node_exporter'

if ufw status numbered | grep -Ei "${{SCRAPE_PORT}}(/tcp)?[[:space:]]+ALLOW IN[[:space:]]+Anywhere" >/dev/null; then
  echo "warning: broad lower-priority ALLOW rule for TCP $SCRAPE_PORT is still present; the inserted deny should take precedence, but review 'sudo ufw status numbered' and delete stale broad rules during cleanup."
fi

ufw status numbered | grep -E "Status:|${{SCRAPE_PORT}}" || true
echo "good: staged node_exporter access-control policy inserted for $EXPECTED_HOST; verify approved Prometheus scrape and a non-approved negative check before marking runtime hardening complete"
''',
