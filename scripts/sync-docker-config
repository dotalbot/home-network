#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DOCKER_DIR="${DOCKER_DIR:-/opt/docker}"
HOSTNAME_SHORT="$(hostname -s)"
DOCKER_GROUP="${DOCKER_GROUP:-dockerops}"

SRC_BASE="${REPO_ROOT}/docker/docker-compose.yml"
SRC_HOST="${REPO_ROOT}/docker/hosts/${HOSTNAME_SHORT}.yaml"

DEST_BASE="${DOCKER_DIR}/docker-compose.yml"
DEST_HOST_DIR="${DOCKER_DIR}/hosts"
DEST_HOST="${DEST_HOST_DIR}/${HOSTNAME_SHORT}.yaml"

if [ ! -f "$SRC_BASE" ]; then
  echo "not good: missing $SRC_BASE"
  exit 1
fi

if [ ! -f "$SRC_HOST" ]; then
  echo "not good: missing $SRC_HOST"
  exit 1
fi

needs_sudo=0
if [ ! -d "$DOCKER_DIR" ] || [ ! -w "$DOCKER_DIR" ]; then
  needs_sudo=1
fi

can_sudo=0
if command -v sudo >/dev/null 2>&1 && sudo -n true >/dev/null 2>&1; then
  can_sudo=1
fi

run_privileged() {
  if [ "$needs_sudo" -eq 1 ]; then
    sudo "$@"
  else
    "$@"
  fi
}

set_managed_perms() {
  local target="$1"
  if [ "$needs_sudo" -eq 1 ]; then
    sudo chown -R root:"$DOCKER_GROUP" "$target"
    return
  fi

  if [ "$(id -u)" -eq 0 ]; then
    chown -R root:"$DOCKER_GROUP" "$target"
    return
  fi

  # Non-root dockerops operators can update group-writable files in /opt/docker,
  # but cannot chgrp/chmod root-owned files. Treat matching group ownership as OK.
  # Skip files where chgrp fails (root-owned runtime data like alertmanager silences/nflog).
  if [ "$(stat -c %G "$target")" != "$DOCKER_GROUP" ]; then
    chgrp -R "$DOCKER_GROUP" "$target" 2>/dev/null || true
  else
    # Already dockerops-owned at top level, but some nested files may be root-owned.
    # Best-effort: try recursive chgrp, silently skip individual permission failures.
    chgrp -R "$DOCKER_GROUP" "$target" 2>/dev/null || true
  fi
}

run_privileged mkdir -p "$DEST_HOST_DIR"

run_privileged cp "$SRC_BASE" "$DEST_BASE"
run_privileged cp "$SRC_HOST" "$DEST_HOST"

set_managed_perms "$DEST_BASE"
set_managed_perms "$DEST_HOST"
if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
  run_privileged chmod 664 "$DEST_BASE" "$DEST_HOST"
else
  [ -O "$DEST_BASE" ] && chmod 664 "$DEST_BASE"
  [ -O "$DEST_HOST" ] && chmod 664 "$DEST_HOST"
fi

SRC_HOMEPAGE="${REPO_ROOT}/docker/appdata/homepage"
DEST_HOMEPAGE="${DOCKER_DIR}/appdata/homepage"
SRC_NETWORK_MAP="${REPO_ROOT}/docker/appdata/network-map"
DEST_NETWORK_MAP="${DOCKER_DIR}/appdata/network-map"
SRC_LOKI_CONFIG="${REPO_ROOT}/docker/appdata/loki/config"
DEST_LOKI_CONFIG="${DOCKER_DIR}/appdata/loki/config"
DEST_LOKI_DATA="${DOCKER_DIR}/appdata/loki/data"
SRC_ALLOY_CONFIG="${REPO_ROOT}/docker/appdata/alloy/config"
DEST_ALLOY_CONFIG="${DOCKER_DIR}/appdata/alloy/config"
DEST_ALLOY_DATA="${DOCKER_DIR}/appdata/alloy/data"
SRC_GRAFANA_PROVISIONING="${REPO_ROOT}/docker/appdata/grafana-provisioning"
DEST_GRAFANA_PROVISIONING="${DOCKER_DIR}/appdata/grafana-provisioning"
SRC_PROMETHEUS_CONFIG="${REPO_ROOT}/docker/appdata/prometheus/config"
DEST_PROMETHEUS_CONFIG="${DOCKER_DIR}/appdata/prometheus/config"
DEST_PROMETHEUS_DATA="${DOCKER_DIR}/appdata/prometheus/data"
SRC_ALERTMANAGER_CONFIG="${REPO_ROOT}/docker/appdata/alertmanager/config"
DEST_ALERTMANAGER_CONFIG="${DOCKER_DIR}/appdata/alertmanager/config"
DEST_ALERTMANAGER_DATA="${DOCKER_DIR}/appdata/alertmanager/data"
SRC_ALERTMANAGER_DISCORD_BRIDGE="${REPO_ROOT}/docker/appdata/alertmanager-discord-bridge"
DEST_ALERTMANAGER_DISCORD_BRIDGE="${DOCKER_DIR}/appdata/alertmanager-discord-bridge"
SRC_POSTGRES_CONFIG="${REPO_ROOT}/docker/appdata/postgres/config"
DEST_POSTGRES_CONFIG="${DOCKER_DIR}/appdata/postgres/config"
DEST_POSTGRES_DUMPS="${DOCKER_DIR}/appdata/postgres/logical-dumps"
SRC_CRAWL4AI_CONFIG="${REPO_ROOT}/docker/appdata/crawl4ai"
DEST_CRAWL4AI_CONFIG="${DOCKER_DIR}/appdata/crawl4ai"
SRC_STORAGE_MONITORING="${REPO_ROOT}/docker/appdata/storage-monitoring"
DEST_STORAGE_MONITORING="${DOCKER_DIR}/appdata/storage-monitoring"
DEST_BIN="${DOCKER_DIR}/bin"
RSYNC_OPTS=(-rtD --delete --omit-dir-times --no-perms --no-owner --no-group)

if [ -d "$SRC_HOMEPAGE" ]; then
  run_privileged mkdir -p "$DEST_HOMEPAGE"
  run_privileged rsync "${RSYNC_OPTS[@]}" --exclude "/logs/" "$SRC_HOMEPAGE"/ "$DEST_HOMEPAGE"/
  set_managed_perms "$DEST_HOMEPAGE"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_HOMEPAGE"
  elif [ -O "$DEST_HOMEPAGE" ]; then
    chmod -R 775 "$DEST_HOMEPAGE"
  fi
fi

if [ -d "$SRC_NETWORK_MAP" ]; then
  run_privileged mkdir -p "$DEST_NETWORK_MAP"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_NETWORK_MAP"/ "$DEST_NETWORK_MAP"/
  set_managed_perms "$DEST_NETWORK_MAP"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_NETWORK_MAP"
  elif [ -O "$DEST_NETWORK_MAP" ]; then
    chmod -R 775 "$DEST_NETWORK_MAP"
  fi
fi

if [ -d "$SRC_LOKI_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_LOKI_CONFIG" "$DEST_LOKI_DATA"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_LOKI_CONFIG"/ "$DEST_LOKI_CONFIG"/
  set_managed_perms "$DEST_LOKI_CONFIG"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_LOKI_CONFIG"
  elif [ -O "$DEST_LOKI_CONFIG" ]; then
    chmod -R 775 "$DEST_LOKI_CONFIG"
  fi
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chown -R 10001:10001 "$DEST_LOKI_DATA"
    run_privileged chmod -R 777 "$DEST_LOKI_DATA"
  elif [ "$can_sudo" -eq 1 ]; then
    sudo chown -R 10001:10001 "$DEST_LOKI_DATA"
    sudo chmod -R 777 "$DEST_LOKI_DATA"
  elif [ -O "$DEST_LOKI_DATA" ]; then
    chown -R 10001:10001 "$DEST_LOKI_DATA" 2>/dev/null || true
    chmod -R 777 "$DEST_LOKI_DATA" 2>/dev/null || echo "warning: $DEST_LOKI_DATA contains files whose modes could not be updated" >&2
  else
    echo "warning: $DEST_LOKI_DATA may need writable permissions for Loki writes" >&2
  fi
fi


if [ -d "$SRC_ALLOY_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_ALLOY_CONFIG" "$DEST_ALLOY_DATA"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_ALLOY_CONFIG"/ "$DEST_ALLOY_CONFIG"/
  set_managed_perms "$DEST_ALLOY_CONFIG"
  set_managed_perms "$DEST_ALLOY_DATA"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_ALLOY_CONFIG" "$DEST_ALLOY_DATA"
  else
    [ -O "$DEST_ALLOY_CONFIG" ] && chmod -R 775 "$DEST_ALLOY_CONFIG"
    if [ -O "$DEST_ALLOY_DATA" ]; then
      chmod -R 775 "$DEST_ALLOY_DATA" 2>/dev/null || echo "warning: $DEST_ALLOY_DATA contains files whose modes could not be updated" >&2
    fi
  fi
fi

if [ -d "$SRC_GRAFANA_PROVISIONING" ]; then
  run_privileged mkdir -p "$DEST_GRAFANA_PROVISIONING"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_GRAFANA_PROVISIONING"/ "$DEST_GRAFANA_PROVISIONING"/
  set_managed_perms "$DEST_GRAFANA_PROVISIONING"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_GRAFANA_PROVISIONING"
  elif [ -O "$DEST_GRAFANA_PROVISIONING" ]; then
    chmod -R 775 "$DEST_GRAFANA_PROVISIONING"
  fi
fi

if [ -d "$SRC_PROMETHEUS_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_PROMETHEUS_CONFIG" "$DEST_PROMETHEUS_DATA"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_PROMETHEUS_CONFIG"/ "$DEST_PROMETHEUS_CONFIG"/
  set_managed_perms "$DEST_PROMETHEUS_CONFIG"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_PROMETHEUS_CONFIG"
  elif [ -O "$DEST_PROMETHEUS_CONFIG" ]; then
    chmod -R 775 "$DEST_PROMETHEUS_CONFIG"
  fi
  # Do not recursively rewrite Prometheus TSDB ownership during routine syncs.
  # Existing runtime data is state, not source-managed config. A brand-new empty
  # data directory still needs Prometheus-compatible ownership before first run.
  if [ -z "$(run_privileged find "$DEST_PROMETHEUS_DATA" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    run_privileged chown 65534:65534 "$DEST_PROMETHEUS_DATA" 2>/dev/null || true
    run_privileged chmod 775 "$DEST_PROMETHEUS_DATA" 2>/dev/null || true
  fi
fi

if [ -d "$SRC_ALERTMANAGER_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_ALERTMANAGER_CONFIG" "$DEST_ALERTMANAGER_DATA"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_ALERTMANAGER_CONFIG"/ "$DEST_ALERTMANAGER_CONFIG"/
  set_managed_perms "$DEST_ALERTMANAGER_CONFIG"
  set_managed_perms "$DEST_ALERTMANAGER_DATA"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_ALERTMANAGER_CONFIG"
  elif [ -O "$DEST_ALERTMANAGER_CONFIG" ]; then
    chmod -R 775 "$DEST_ALERTMANAGER_CONFIG"
  fi
  if [ -z "$(run_privileged find "$DEST_ALERTMANAGER_DATA" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    run_privileged chown -R 65534:65534 "$DEST_ALERTMANAGER_DATA" 2>/dev/null || true
    run_privileged chmod -R 775 "$DEST_ALERTMANAGER_DATA" 2>/dev/null || true
  fi
fi

if [ -d "$SRC_ALERTMANAGER_DISCORD_BRIDGE" ]; then
  run_privileged mkdir -p "$DEST_ALERTMANAGER_DISCORD_BRIDGE"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_ALERTMANAGER_DISCORD_BRIDGE"/ "$DEST_ALERTMANAGER_DISCORD_BRIDGE"/
  set_managed_perms "$DEST_ALERTMANAGER_DISCORD_BRIDGE"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_ALERTMANAGER_DISCORD_BRIDGE"
  elif [ -O "$DEST_ALERTMANAGER_DISCORD_BRIDGE" ]; then
    chmod -R 775 "$DEST_ALERTMANAGER_DISCORD_BRIDGE"
  fi
fi

if [ -d "$SRC_POSTGRES_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_POSTGRES_CONFIG" "$DEST_POSTGRES_DUMPS"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_POSTGRES_CONFIG"/ "$DEST_POSTGRES_CONFIG"/
  set_managed_perms "$DEST_POSTGRES_CONFIG"
  set_managed_perms "$DEST_POSTGRES_DUMPS"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_POSTGRES_CONFIG"
    run_privileged chmod -R 770 "$DEST_POSTGRES_DUMPS"
  else
    [ -O "$DEST_POSTGRES_CONFIG" ] && chmod -R 775 "$DEST_POSTGRES_CONFIG"
    [ -O "$DEST_POSTGRES_DUMPS" ] && chmod -R 770 "$DEST_POSTGRES_DUMPS"
  fi
fi

if [ -d "$SRC_CRAWL4AI_CONFIG" ]; then
  run_privileged mkdir -p "$DEST_CRAWL4AI_CONFIG"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_CRAWL4AI_CONFIG"/ "$DEST_CRAWL4AI_CONFIG"/
  set_managed_perms "$DEST_CRAWL4AI_CONFIG"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_CRAWL4AI_CONFIG"
  elif [ -O "$DEST_CRAWL4AI_CONFIG" ]; then
    chmod -R 775 "$DEST_CRAWL4AI_CONFIG"
  fi
fi

if [ -d "$SRC_STORAGE_MONITORING" ]; then
  run_privileged mkdir -p "$DEST_STORAGE_MONITORING"
  # Keep generated reports and duc indexes as runtime state. The source tree only
  # manages scripts/templates; deleting root-owned reports during routine sync
  # breaks non-root dockerops operators.
  run_privileged rsync "${RSYNC_OPTS[@]}" --exclude "/reports/" --exclude "/duc/" "$SRC_STORAGE_MONITORING"/ "$DEST_STORAGE_MONITORING"/
  set_managed_perms "$DEST_STORAGE_MONITORING"
  # Only chmod source-managed top-level scripts here. Generated reports/indexes
  # may be root-owned after systemd runs and should not make sync fail.
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod 775 "$DEST_STORAGE_MONITORING"
    run_privileged chmod 775 "$DEST_STORAGE_MONITORING"/*.sh 2>/dev/null || true
  else
    [ -O "$DEST_STORAGE_MONITORING" ] && chmod 775 "$DEST_STORAGE_MONITORING"
    chmod 775 "$DEST_STORAGE_MONITORING"/*.sh 2>/dev/null || true
  fi
fi

run_privileged mkdir -p "$DEST_BIN"
for helper in postgres-logical-dump postgres-bootstrap-manyfold postgres-firewall-docker-user; do
  if [ -f "${REPO_ROOT}/scripts/${helper}" ]; then
    dest_helper="${DEST_BIN}/${helper}"
    if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ] || [ -w "$dest_helper" ] || { [ ! -e "$dest_helper" ] && [ -w "$DEST_BIN" ]; }; then
      run_privileged cp "${REPO_ROOT}/scripts/${helper}" "$dest_helper"
      set_managed_perms "$dest_helper"
      if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
        run_privileged chmod 775 "$dest_helper"
      elif [ -O "$dest_helper" ]; then
        chmod 775 "$dest_helper"
      fi
    else
      echo "warning: cannot update $dest_helper without sudo or write ownership; leaving existing helper in place" >&2
    fi
  fi
done

echo "good"
