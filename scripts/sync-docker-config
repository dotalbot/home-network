#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DOCKER_DIR="${DOCKER_DIR:-/opt/docker}"
HOSTNAME_SHORT="$(hostname -s)"
DOCKER_GROUP="${DOCKER_GROUP:-dockerops}"

SRC_BASE="${REPO_ROOT}/docker/docker-compose.yml"
SRC_HOST="${REPO_ROOT}/docker/hosts/${HOSTNAME_SHORT}.yaml"

DEST_BASE="${DOCKER_DIR}/docker-compose.yml"
DEST_HOST_DIR="${DOCKER_DIR}/hosts"
DEST_HOST="${DEST_HOST_DIR}/${HOSTNAME_SHORT}.yaml"

if [ ! -f "$SRC_BASE" ]; then
  echo "not good: missing $SRC_BASE"
  exit 1
fi

if [ ! -f "$SRC_HOST" ]; then
  echo "not good: missing $SRC_HOST"
  exit 1
fi

needs_sudo=0
if [ ! -d "$DOCKER_DIR" ] || [ ! -w "$DOCKER_DIR" ]; then
  needs_sudo=1
fi

run_privileged() {
  if [ "$needs_sudo" -eq 1 ]; then
    sudo "$@"
  else
    "$@"
  fi
}

set_managed_perms() {
  local target="$1"
  if [ "$needs_sudo" -eq 1 ]; then
    sudo chown -R root:"$DOCKER_GROUP" "$target"
    return
  fi

  if [ "$(id -u)" -eq 0 ]; then
    chown -R root:"$DOCKER_GROUP" "$target"
    return
  fi

  # Non-root dockerops operators can update group-writable files in /opt/docker,
  # but cannot chgrp/chmod root-owned files. Treat matching group ownership as OK.
  if [ "$(stat -c %G "$target")" != "$DOCKER_GROUP" ]; then
    chgrp -R "$DOCKER_GROUP" "$target"
  fi
}

run_privileged mkdir -p "$DEST_HOST_DIR"

run_privileged cp "$SRC_BASE" "$DEST_BASE"
run_privileged cp "$SRC_HOST" "$DEST_HOST"

set_managed_perms "$DEST_BASE"
set_managed_perms "$DEST_HOST"
if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
  run_privileged chmod 664 "$DEST_BASE" "$DEST_HOST"
else
  [ -O "$DEST_BASE" ] && chmod 664 "$DEST_BASE"
  [ -O "$DEST_HOST" ] && chmod 664 "$DEST_HOST"
fi

SRC_HOMEPAGE="${REPO_ROOT}/docker/appdata/homepage"
DEST_HOMEPAGE="${DOCKER_DIR}/appdata/homepage"
SRC_NETWORK_MAP="${REPO_ROOT}/docker/appdata/network-map"
DEST_NETWORK_MAP="${DOCKER_DIR}/appdata/network-map"
RSYNC_OPTS=(-rtD --delete --omit-dir-times --no-perms --no-owner --no-group)

if [ -d "$SRC_HOMEPAGE" ]; then
  run_privileged mkdir -p "$DEST_HOMEPAGE"
  run_privileged rsync "${RSYNC_OPTS[@]}" --exclude "/logs/" "$SRC_HOMEPAGE"/ "$DEST_HOMEPAGE"/
  set_managed_perms "$DEST_HOMEPAGE"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_HOMEPAGE"
  elif [ -O "$DEST_HOMEPAGE" ]; then
    chmod -R 775 "$DEST_HOMEPAGE"
  fi
fi

if [ -d "$SRC_NETWORK_MAP" ]; then
  run_privileged mkdir -p "$DEST_NETWORK_MAP"
  run_privileged rsync "${RSYNC_OPTS[@]}" "$SRC_NETWORK_MAP"/ "$DEST_NETWORK_MAP"/
  set_managed_perms "$DEST_NETWORK_MAP"
  if [ "$needs_sudo" -eq 1 ] || [ "$(id -u)" -eq 0 ]; then
    run_privileged chmod -R 775 "$DEST_NETWORK_MAP"
  elif [ -O "$DEST_NETWORK_MAP" ]; then
    chmod -R 775 "$DEST_NETWORK_MAP"
  fi
fi

echo "good"
