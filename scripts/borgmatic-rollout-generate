#!/usr/bin/env python3
"""Generate inventory-driven Borgmatic rollout scripts.

This creates /tmp/borgmatic-rollout-<host>/stage-*.sh scripts for every
borg-enabled host in inventory/backups.yml that has a repository_path. The
scripts are intentionally stage-based: operators run each step manually with
sudo on the matching host.
"""

from __future__ import annotations

import json
import os
import re
import stat
import sys
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:  # pragma: no cover - exercised by operator environment
    print("not good: missing python3-yaml", file=sys.stderr)
    raise SystemExit(1)


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_INVENTORY = REPO_ROOT / "inventory" / "backups.yml"
SAFE_HOST_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9-]{0,62}$")
SAFE_USER_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_-]{0,63}$")
SAFE_TARGET_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.:-]{0,252}$")
SAFE_ABSOLUTE_PATH_RE = re.compile(r"^/[A-Za-z0-9._+/@:-]+$")
SAFE_LOKI_URL_RE = re.compile(r"^https?://[A-Za-z0-9_.:-]+/loki/api/v1/push$")
SAFE_MQTT_HOST_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.-]{0,252}$")
SAFE_MQTT_TOPIC_PREFIX_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_/-]{0,127}$")
SAFE_LABEL_KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]{0,62}$")
SAFE_LABEL_VALUE_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$")

HEADER = r'''#!/usr/bin/env bash
set -euo pipefail

EXPECTED_HOST="__HOST__"
BACKUP_USER="__BACKUP_USER__"
TARGET_IP="__TARGET_IP__"
REPO_PATH="__REPO_PATH__"
REPO="ssh://${BACKUP_USER}@${TARGET_IP}${REPO_PATH}"
SECRETS_DIR="/opt/docker/.secrets"
PASSPHRASE_FILE="${SECRETS_DIR}/borgmatic-passphrase"
KEY_EXPORT_FILE="${SECRETS_DIR}/borg-${EXPECTED_HOST}-repokey.txt"
CONFIG_DIR="/etc/borgmatic"
CONFIG_FILE="${CONFIG_DIR}/config.yaml"
STATUS_DIR="/var/lib/home-network/backup-status"
STATUS_FILE="${STATUS_DIR}/${EXPECTED_HOST}.json"
LOG_DIR="/var/log/home-network-borgmatic"
TEXTFILE_DIR="/var/lib/node_exporter/textfile_collector"
PROM_FILE="${TEXTFILE_DIR}/borgmatic_${EXPECTED_HOST}.prom"
__BORGMATIC_MQTT_VARS__

require_root() {
  if [ "$(id -u)" -ne 0 ]; then
    echo "not good: run with sudo/root" >&2
    exit 1
  fi
}

require_host() {
  local actual
  actual="$(hostname -s)"
  if [ "$actual" != "$EXPECTED_HOST" ]; then
    echo "not good: this script is for ${EXPECTED_HOST}, current host is ${actual}" >&2
    exit 1
  fi
}

repo_reachable() {
  if ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=yes "${BACKUP_USER}@${TARGET_IP}" "test -d '${REPO_PATH}' && test -f '${REPO_PATH}/config'" >/dev/null 2>&1; then
    printf '1'
  else
    printf '0'
  fi
}

write_status() {
  local status="$1"
  local exit_code="$2"
  local archive="${3:-}"
  local message="${4:-}"
  local duration="${5:-0}"
  local reachable="${6:-$(repo_reachable)}"
  install -d -m 755 -o root -g root "$STATUS_DIR"
  python3 - "$STATUS_FILE" "$EXPECTED_HOST" "$REPO" "$status" "$exit_code" "$archive" "$message" "$duration" "$reachable" <<'PY'
import json, sys
from datetime import datetime, timezone
path, host, repo, status, exit_code, archive, message, duration, reachable = sys.argv[1:]
data = {
    "host": host,
    "repository": repo,
    "updated_at": datetime.now(timezone.utc).isoformat(),
    "status": status,
    "exit_code": int(exit_code),
    "archive_name": archive or None,
    "message": message or None,
    "duration_seconds": int(duration),
    "repository_reachable": reachable == "1",
}
with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, sort_keys=True)
    f.write("\n")
PY
  chmod 644 "$STATUS_FILE"
}

write_prometheus() {
  local status="$1"
  local exit_code="$2"
  local duration="${3:-0}"
  local archive="${4:-}"
  local reachable="${5:-$(repo_reachable)}"
  if [ ! -d "$TEXTFILE_DIR" ]; then
    echo "prometheus textfile collector dir not present, skipped: $TEXTFILE_DIR"
    return 0
  fi
  local ok=0
  [ "$status" = "success" ] && ok=1
  local now
  now="$(date +%s)"
  local tmp
  tmp="${PROM_FILE}.$$"
  python3 - "$tmp" "$EXPECTED_HOST" "$now" "$ok" "$exit_code" "$duration" "$archive" "$reachable" <<'PY'
import sys
path, host, now, ok, exit_code, duration, archive, reachable = sys.argv[1:]
with open(path, "w", encoding="utf-8") as f:
    f.write("# HELP borgmatic_last_run_timestamp_seconds Last Borgmatic run timestamp.\n")
    f.write("# TYPE borgmatic_last_run_timestamp_seconds gauge\n")
    f.write(f'borgmatic_last_run_timestamp_seconds{{host="{host}"}} {now}\n')
    f.write("# HELP borgmatic_last_run_success Last Borgmatic run success, 1 for success and 0 for failure.\n")
    f.write("# TYPE borgmatic_last_run_success gauge\n")
    f.write(f'borgmatic_last_run_success{{host="{host}"}} {ok}\n')
    f.write("# HELP borgmatic_last_run_exit_code Last Borgmatic run exit code.\n")
    f.write("# TYPE borgmatic_last_run_exit_code gauge\n")
    f.write(f'borgmatic_last_run_exit_code{{host="{host}"}} {exit_code}\n')
    f.write("# HELP borgmatic_last_run_duration_seconds Last Borgmatic run duration in seconds.\n")
    f.write("# TYPE borgmatic_last_run_duration_seconds gauge\n")
    f.write(f'borgmatic_last_run_duration_seconds{{host="{host}"}} {duration}\n')
    f.write("# HELP borgmatic_repository_reachable Last observed Borg repository reachability, 1 for reachable and 0 for unreachable.\n")
    f.write("# TYPE borgmatic_repository_reachable gauge\n")
    f.write(f'borgmatic_repository_reachable{{host="{host}"}} {reachable}\n')
    if archive:
        esc = archive.replace('\\', '\\\\').replace('\n', '\\n').replace('"', '\\"')
        f.write("# HELP borgmatic_last_archive_info Last observed Borg archive name as an info metric.\n")
        f.write("# TYPE borgmatic_last_archive_info gauge\n")
        f.write(f'borgmatic_last_archive_info{{host="{host}",archive_name="{esc}"}} 1\n')
PY
  mv "$tmp" "$PROM_FILE"
  chmod 644 "$PROM_FILE"
  echo "wrote prometheus metrics: $PROM_FILE"
}


mqtt_topic() {
  local suffix="$1"
  printf '%s/backups/%s/borgmatic/%s' "$MQTT_TOPIC_PREFIX" "$EXPECTED_HOST" "$suffix"
}

publish_mqtt() {
  local topic_suffix="$1"
  local status="$2"
  local exit_code="$3"
  local archive="${4:-}"
  local message="${5:-}"
  local duration="${6:-0}"
  local retain="${7:-0}"

  [ "${MQTT_EVENTS_ENABLED:-0}" = "1" ] || return 0

  if ! command -v mosquitto_pub >/dev/null 2>&1; then
    echo "warning: mosquitto_pub not installed; skipped MQTT publish" >&2
    return 0
  fi

  local topic payload
  topic="$(mqtt_topic "$topic_suffix")"
  payload="$(python3 - "$EXPECTED_HOST" "$status" "$exit_code" "$archive" "$message" "$duration" <<'PY'
import json, sys
from datetime import datetime, timezone

host, status, exit_code, archive, message, duration = sys.argv[1:]
severity = "info"
if status == "failure":
    severity = "critical"
elif status == "start":
    severity = "info"

data = {
    "schema_version": 1,
    "component": "borgmatic",
    "host": host,
    "status": status,
    "event_at": datetime.now(timezone.utc).isoformat(),
    "duration_seconds": int(duration),
    "exit_code": int(exit_code),
    "archive": archive or None,
    "severity": severity,
    "message": message or None,
    "loki_url_hint": f"grafana explore query labels host={host} job=borgmatic",
}
print(json.dumps(data, sort_keys=True, separators=(",", ":")))
PY
)"

  local auth_args=()
  if [ -n "${MQTT_USERNAME:-}" ] && [ -n "${MQTT_PASSWORD_FILE:-}" ]; then
    if [ -r "$MQTT_PASSWORD_FILE" ]; then
      auth_args=(-u "$MQTT_USERNAME" -P "$(tr -d '\r\n' < "$MQTT_PASSWORD_FILE")")
    else
      echo "warning: MQTT password file is not readable; skipped MQTT publish" >&2
      return 0
    fi
  fi

  if [ "$retain" = "1" ]; then
    mosquitto_pub -h "$MQTT_BROKER_HOST" -p "$MQTT_BROKER_PORT" "${auth_args[@]}" -t "$topic" -r -m "$payload" \
      || echo "warning: MQTT retained state publish failed: $topic" >&2
  else
    mosquitto_pub -h "$MQTT_BROKER_HOST" -p "$MQTT_BROKER_PORT" "${auth_args[@]}" -t "$topic" -m "$payload" \
      || echo "warning: MQTT event publish failed: $topic" >&2
  fi
}

publish_backup_event_and_state() {
  local status="$1"
  local exit_code="$2"
  local archive="${3:-}"
  local message="${4:-}"
  local duration="${5:-0}"

  publish_mqtt "event" "$status" "$exit_code" "$archive" "$message" "$duration" 0
  publish_mqtt "state" "$status" "$exit_code" "$archive" "$message" "$duration" "${MQTT_RETAIN_STATE:-1}"
}

latest_archive() {
  { borgmatic list 2>/dev/null || true; } | awk -v h="$EXPECTED_HOST" '$1 ~ "^" h "-" {name=$1} END{print name}'
}

require_root
require_host
'''

STAGES = {
"stage-00-bootstrap-host.sh": r'''
echo "Bootstrap local directories for ${EXPECTED_HOST}"
install -d -m 755 -o root -g root /opt/docker
install -d -m 755 -o root -g root /opt/docker/appdata
install -d -m 755 -o root -g root /opt/docker/hosts
install -d -m 700 -o root -g root "$SECRETS_DIR"
install -d -m 755 -o root -g root "$STATUS_DIR" "$LOG_DIR"
install -d -m 755 -o root -g root "$TEXTFILE_DIR"
SENTINEL="/opt/docker/.home-network-backup-sentinel"
if [ ! -f "$SENTINEL" ]; then
  printf 'home-network backup sentinel for %s\n' "$EXPECTED_HOST" > "$SENTINEL"
fi
chown root:root "$SENTINEL"
chmod 644 "$SENTINEL"
stat -c '%A %U:%G %n' /opt/docker /opt/docker/appdata /opt/docker/hosts "$SECRETS_DIR" "$STATUS_DIR" "$LOG_DIR" "$TEXTFILE_DIR" "$SENTINEL"
echo "good: base directories are present"
echo "note: this stage does not install packages, change SSH keys, initialize repos, or enable services"
''',
"stage-01-preflight.sh": r'''
echo "Preflight for ${EXPECTED_HOST}"
command -v borg >/dev/null || { echo "missing borg" >&2; exit 1; }
command -v borgmatic >/dev/null || { echo "missing borgmatic" >&2; exit 1; }
__SOURCE_PREFLIGHT__
ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=yes "${BACKUP_USER}@${TARGET_IP}" 'hostname && whoami && pwd'
ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=yes "${BACKUP_USER}@${TARGET_IP}" "test -d '${REPO_PATH}' && stat -c '%A %U:%G %n' '${REPO_PATH}'"
echo "good: preflight passed for ${EXPECTED_HOST}"
''',
"stage-02-secrets.sh": r'''
install -d -m 700 -o root -g root "$SECRETS_DIR"
if [ -f "$PASSPHRASE_FILE" ]; then
  echo "passphrase file already exists, not replacing: $PASSPHRASE_FILE"
else
  openssl rand -base64 48 > "$PASSPHRASE_FILE"
  echo "created passphrase file: $PASSPHRASE_FILE"
fi
chown root:root "$PASSPHRASE_FILE"
chmod 600 "$PASSPHRASE_FILE"
stat -c '%A %U:%G %n' "$SECRETS_DIR" "$PASSPHRASE_FILE"
echo "Save the passphrase in your password manager with label: Borg passphrase - ${EXPECTED_HOST}"
echo "View it with: sudo cat ${PASSPHRASE_FILE}"
''',
"stage-03-init-repo.sh": r'''
if ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=yes "${BACKUP_USER}@${TARGET_IP}" "test -f '${REPO_PATH}/config'"; then
  echo "repo already initialized: ${REPO_PATH}"
  exit 0
fi
BORG_PASSPHRASE="$(cat "$PASSPHRASE_FILE")" borg init --encryption=repokey-blake2 "$REPO"
echo "good: initialized ${REPO}"
''',
"stage-04-export-key.sh": r'''
if [ -f "$KEY_EXPORT_FILE" ]; then
  echo "key export already exists, not replacing: $KEY_EXPORT_FILE"
else
  umask 077
  BORG_PASSPHRASE="$(cat "$PASSPHRASE_FILE")" borg key export "$REPO" "$KEY_EXPORT_FILE"
  echo "exported repo key: $KEY_EXPORT_FILE"
fi
chown root:root "$KEY_EXPORT_FILE"
chmod 600 "$KEY_EXPORT_FILE"
stat -c '%A %U:%G %n' "$KEY_EXPORT_FILE"
echo "Save this key file in your password manager with label: Borg repo key - ${EXPECTED_HOST}"
echo "View it with: sudo cat ${KEY_EXPORT_FILE}"
''',
"stage-05-configure-borgmatic.sh": r'''
install -d -m 755 -o root -g root "$CONFIG_DIR"
if [ -f "$CONFIG_FILE" ]; then
  if [ "${ALLOW_OVERWRITE_BORGMATIC_CONFIG:-0}" != "1" ]; then
    echo "not good: config already exists: $CONFIG_FILE" >&2
    echo "Re-run with: sudo ALLOW_OVERWRITE_BORGMATIC_CONFIG=1 $0" >&2
    exit 1
  fi
  backup="${CONFIG_FILE}.bak.$(date +%Y%m%d-%H%M%S)"
  cp -a "$CONFIG_FILE" "$backup"
  echo "backed up existing config: $backup"
fi
cat > "$CONFIG_FILE" <<YAML
source_directories:
__SOURCE_DIRECTORIES__
repositories:
  - path: ${REPO}
    label: ${EXPECTED_HOST}

encryption_passcommand: "cat ${PASSPHRASE_FILE}"

archive_name_format: '${EXPECTED_HOST}-{now:%Y-%m-%dT%H:%M:%S}'

__LOKI_MONITORING__keep_daily: 7
keep_weekly: 4
keep_monthly: 6

checks:
  - name: repository
  - name: archives
    frequency: 2 weeks

exclude_patterns:
  - /opt/docker/.secrets
  - /opt/docker/.secrets/**
  - /opt/docker/appdata/*/cache
  - /opt/docker/appdata/*/logs
  - /opt/docker/appdata/*/tmp
  - /opt/docker/appdata/*/temp
  - /opt/docker/**/.cache
  - /opt/docker/**/node_modules
  - /opt/docker/**/.venv
YAML
chown root:root "$CONFIG_FILE"
chmod 600 "$CONFIG_FILE"
borgmatic config validate
stat -c '%A %U:%G %n' "$CONFIG_FILE"
echo "good: borgmatic config written and validated"
''',
"stage-06-manual-backup.sh": r'''
install -d -m 755 -o root -g root "$LOG_DIR" "$STATUS_DIR"
start="$(date +%s)"
log="${LOG_DIR}/${EXPECTED_HOST}-create-$(date +%Y%m%d-%H%M%S).log"
publish_backup_event_and_state "start" 0 "" "manual backup started" 0
set +e
borgmatic create --stats 2>&1 | tee "$log"
rc=${PIPESTATUS[0]}
set -e
end="$(date +%s)"
duration=$((end - start))
archive=""
if [ "$rc" -eq 0 ]; then
  archive="$(latest_archive)"
  reachable="$(repo_reachable)"
  write_status "success" 0 "$archive" "manual backup completed; log=${log}" "$duration" "$reachable"
  write_prometheus "success" 0 "$duration" "$archive" "$reachable"
  publish_backup_event_and_state "success" 0 "$archive" "manual backup completed" "$duration"
  echo "good: backup completed; archive=${archive}; log=${log}"
else
  reachable="$(repo_reachable)"
  write_status "failure" "$rc" "" "manual backup failed; see ${log}" "$duration" "$reachable"
  write_prometheus "failure" "$rc" "$duration" "" "$reachable"
  publish_backup_event_and_state "failure" "$rc" "" "manual backup failed; see Loki/Grafana hint" "$duration"
  echo "not good: backup failed; rc=${rc}; log=${log}" >&2
  exit "$rc"
fi
''',
"stage-07-check-and-restore-test.sh": r'''
borgmatic check
restore_source=""
for candidate in __RESTORE_CANDIDATES__; do
  if [ -f "$candidate" ]; then
    restore_source="$candidate"
    break
  fi
done
if [ -z "$restore_source" ]; then
  echo "not good: no restore-test source found for ${EXPECTED_HOST}" >&2
  echo "checked configured important paths for a readable file plus /opt/docker/hosts/${EXPECTED_HOST}.yaml and /opt/docker/docker-compose.yml" >&2
  exit 1
fi
archive_path="${restore_source#/}"
restore_dir="/tmp/borgmatic-restore-test-${EXPECTED_HOST}-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$restore_dir"
borgmatic extract --archive latest --path "$archive_path" --destination "$restore_dir"
diff -q "$restore_source" "${restore_dir}/${archive_path}"
archive="$(latest_archive)"
write_status "success" 0 "$archive" "check and restore test passed: ${restore_source} -> ${restore_dir}" 0 "$(repo_reachable)"
echo "RESTORE_TEST_OK ${restore_dir}"
''',
"stage-08-enable-timer.sh": r"""
WRAPPER="/usr/local/sbin/home-network-borgmatic-run-${EXPECTED_HOST}"
SERVICE="/etc/systemd/system/home-network-borgmatic-${EXPECTED_HOST}.service"
TIMER="/etc/systemd/system/home-network-borgmatic-${EXPECTED_HOST}.timer"
if systemctl is-enabled --quiet borgmatic.timer 2>/dev/null || systemctl is-active --quiet borgmatic.timer 2>/dev/null; then
  if [ "${ALLOW_DISABLE_STOCK_BORGMATIC_TIMER:-0}" != "1" ]; then
    echo "not good: stock borgmatic.timer is enabled or active" >&2
    echo "This managed timer replaces it to avoid duplicate backups." >&2
    echo "Re-run with: sudo ALLOW_DISABLE_STOCK_BORGMATIC_TIMER=1 $0" >&2
    exit 1
  fi
fi
existing_managed=0
for managed_file in "$WRAPPER" "$SERVICE" "$TIMER"; do
  [ -e "$managed_file" ] && existing_managed=1 && echo "managed file exists: $managed_file"
done
if [ "$existing_managed" -eq 1 ] && [ "${ALLOW_OVERWRITE_MANAGED_BORGMATIC_TIMER:-0}" != "1" ]; then
  echo "not good: managed Borgmatic timer files already exist" >&2
  echo "Re-run with: sudo ALLOW_OVERWRITE_MANAGED_BORGMATIC_TIMER=1 $0" >&2
  exit 1
fi
if [ "$existing_managed" -eq 1 ]; then
  backup_dir="/root/home-network-borgmatic-managed-backup-${EXPECTED_HOST}-$(date +%Y%m%d-%H%M%S)"
  install -d -m 700 -o root -g root "$backup_dir"
  for managed_file in "$WRAPPER" "$SERVICE" "$TIMER"; do
    [ -e "$managed_file" ] && cp -a "$managed_file" "$backup_dir/"
  done
  echo "backed up existing managed files to: $backup_dir"
fi
cat > "$WRAPPER" <<'SH'
#!/usr/bin/env bash
set -euo pipefail
EXPECTED_HOST="__HOST__"
actual_host="$(hostname -s)"
if [ "$actual_host" != "$EXPECTED_HOST" ]; then
  echo "not good: wrapper is for ${EXPECTED_HOST}, current host is ${actual_host}" >&2
  exit 1
fi
BACKUP_USER="__BACKUP_USER__"
TARGET_IP="__TARGET_IP__"
REPO_PATH="__REPO_PATH__"
REPO="ssh://${BACKUP_USER}@${TARGET_IP}${REPO_PATH}"
STATUS_DIR="/var/lib/home-network/backup-status"
STATUS_FILE="${STATUS_DIR}/${EXPECTED_HOST}.json"
LOG_DIR="/var/log/home-network-borgmatic"
TEXTFILE_DIR="/var/lib/node_exporter/textfile_collector"
PROM_FILE="${TEXTFILE_DIR}/borgmatic_${EXPECTED_HOST}.prom"
__BORGMATIC_MQTT_VARS__
repo_reachable() {
  if ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=yes "${BACKUP_USER}@${TARGET_IP}" "test -d '${REPO_PATH}' && test -f '${REPO_PATH}/config'" >/dev/null 2>&1; then
    printf '1'
  else
    printf '0'
  fi
}

write_status() {
  local status="$1"
  local exit_code="$2"
  local archive="${3:-}"
  local message="${4:-}"
  local duration="${5:-0}"
  local reachable="${6:-$(repo_reachable)}"
  install -d -m 755 -o root -g root "$STATUS_DIR"
  python3 - "$STATUS_FILE" "$EXPECTED_HOST" "$REPO" "$status" "$exit_code" "$archive" "$message" "$duration" "$reachable" <<'PY'
import json, sys
from datetime import datetime, timezone
path, host, repo, status, exit_code, archive, message, duration, reachable = sys.argv[1:]
data = {
    "host": host,
    "repository": repo,
    "updated_at": datetime.now(timezone.utc).isoformat(),
    "status": status,
    "exit_code": int(exit_code),
    "archive_name": archive or None,
    "message": message or None,
    "duration_seconds": int(duration),
    "repository_reachable": reachable == "1",
}
with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, sort_keys=True)
    f.write("\n")
PY
  chmod 644 "$STATUS_FILE"
}
write_prometheus() {
  local status="$1"
  local exit_code="$2"
  local duration="${3:-0}"
  local archive="${4:-}"
  local reachable="${5:-$(repo_reachable)}"
  if [ ! -d "$TEXTFILE_DIR" ]; then
    echo "prometheus textfile collector dir not present, skipped: $TEXTFILE_DIR"
    return 0
  fi
  local ok=0
  [ "$status" = "success" ] && ok=1
  local now
  now="$(date +%s)"
  local tmp
  tmp="${PROM_FILE}.$$"
  python3 - "$tmp" "$EXPECTED_HOST" "$now" "$ok" "$exit_code" "$duration" "$archive" "$reachable" <<'PY'
import sys
path, host, now, ok, exit_code, duration, archive, reachable = sys.argv[1:]
with open(path, "w", encoding="utf-8") as f:
    f.write("# HELP borgmatic_last_run_timestamp_seconds Last Borgmatic run timestamp.\n")
    f.write("# TYPE borgmatic_last_run_timestamp_seconds gauge\n")
    f.write(f'borgmatic_last_run_timestamp_seconds{{host="{host}"}} {now}\n')
    f.write("# HELP borgmatic_last_run_success Last Borgmatic run success, 1 for success and 0 for failure.\n")
    f.write("# TYPE borgmatic_last_run_success gauge\n")
    f.write(f'borgmatic_last_run_success{{host="{host}"}} {ok}\n')
    f.write("# HELP borgmatic_last_run_exit_code Last Borgmatic run exit code.\n")
    f.write("# TYPE borgmatic_last_run_exit_code gauge\n")
    f.write(f'borgmatic_last_run_exit_code{{host="{host}"}} {exit_code}\n')
    f.write("# HELP borgmatic_last_run_duration_seconds Last Borgmatic run duration in seconds.\n")
    f.write("# TYPE borgmatic_last_run_duration_seconds gauge\n")
    f.write(f'borgmatic_last_run_duration_seconds{{host="{host}"}} {duration}\n')
    f.write("# HELP borgmatic_repository_reachable Last observed Borg repository reachability, 1 for reachable and 0 for unreachable.\n")
    f.write("# TYPE borgmatic_repository_reachable gauge\n")
    f.write(f'borgmatic_repository_reachable{{host="{host}"}} {reachable}\n')
    if archive:
        esc = archive.replace('\\', '\\\\').replace('\n', '\\n').replace('"', '\\"')
        f.write("# HELP borgmatic_last_archive_info Last observed Borg archive name as an info metric.\n")
        f.write("# TYPE borgmatic_last_archive_info gauge\n")
        f.write(f'borgmatic_last_archive_info{{host="{host}",archive_name="{esc}"}} 1\n')
PY
  mv "$tmp" "$PROM_FILE"
  chmod 644 "$PROM_FILE"
  echo "wrote prometheus metrics: $PROM_FILE"
}

mqtt_topic() {
  local suffix="$1"
  printf '%s/backups/%s/borgmatic/%s' "$MQTT_TOPIC_PREFIX" "$EXPECTED_HOST" "$suffix"
}

publish_mqtt() {
  local topic_suffix="$1"
  local status="$2"
  local exit_code="$3"
  local archive="${4:-}"
  local message="${5:-}"
  local duration="${6:-0}"
  local retain="${7:-0}"

  [ "${MQTT_EVENTS_ENABLED:-0}" = "1" ] || return 0

  if ! command -v mosquitto_pub >/dev/null 2>&1; then
    echo "warning: mosquitto_pub not installed; skipped MQTT publish" >&2
    return 0
  fi

  local topic payload
  topic="$(mqtt_topic "$topic_suffix")"
  payload="$(python3 - "$EXPECTED_HOST" "$status" "$exit_code" "$archive" "$message" "$duration" <<'PY'
import json, sys
from datetime import datetime, timezone

host, status, exit_code, archive, message, duration = sys.argv[1:]
severity = "info"
if status == "failure":
    severity = "critical"
elif status == "start":
    severity = "info"

data = {
    "schema_version": 1,
    "component": "borgmatic",
    "host": host,
    "status": status,
    "event_at": datetime.now(timezone.utc).isoformat(),
    "duration_seconds": int(duration),
    "exit_code": int(exit_code),
    "archive": archive or None,
    "severity": severity,
    "message": message or None,
    "loki_url_hint": f"grafana explore query labels host={host} job=borgmatic",
}
print(json.dumps(data, sort_keys=True, separators=(",", ":")))
PY
)"

  local auth_args=()
  if [ -n "${MQTT_USERNAME:-}" ] && [ -n "${MQTT_PASSWORD_FILE:-}" ]; then
    if [ -r "$MQTT_PASSWORD_FILE" ]; then
      auth_args=(-u "$MQTT_USERNAME" -P "$(tr -d '\r\n' < "$MQTT_PASSWORD_FILE")")
    else
      echo "warning: MQTT password file is not readable; skipped MQTT publish" >&2
      return 0
    fi
  fi

  if [ "$retain" = "1" ]; then
    mosquitto_pub -h "$MQTT_BROKER_HOST" -p "$MQTT_BROKER_PORT" "${auth_args[@]}" -t "$topic" -r -m "$payload" \
      || echo "warning: MQTT retained state publish failed: $topic" >&2
  else
    mosquitto_pub -h "$MQTT_BROKER_HOST" -p "$MQTT_BROKER_PORT" "${auth_args[@]}" -t "$topic" -m "$payload" \
      || echo "warning: MQTT event publish failed: $topic" >&2
  fi
}

publish_backup_event_and_state() {
  local status="$1"
  local exit_code="$2"
  local archive="${3:-}"
  local message="${4:-}"
  local duration="${5:-0}"

  publish_mqtt "event" "$status" "$exit_code" "$archive" "$message" "$duration" 0
  publish_mqtt "state" "$status" "$exit_code" "$archive" "$message" "$duration" "${MQTT_RETAIN_STATE:-1}"
}

latest_archive() {
  { borgmatic list 2>/dev/null || true; } | awk -v h="$EXPECTED_HOST" '$1 ~ "^" h "-" {name=$1} END{print name}'
}
install -d -m 755 -o root -g root "$LOG_DIR" "$STATUS_DIR"
start="$(date +%s)"
log="${LOG_DIR}/${EXPECTED_HOST}-scheduled-$(date +%Y%m%d-%H%M%S).log"
publish_backup_event_and_state "start" 0 "" "scheduled backup started" 0
set +e
{
  borgmatic create --stats
  create_rc=$?
  if [ "$create_rc" -eq 0 ]; then borgmatic prune; prune_rc=$?; else prune_rc=0; fi
  if [ "$create_rc" -eq 0 ] && [ "$prune_rc" -eq 0 ]; then borgmatic compact; compact_rc=$?; else compact_rc=0; fi
  if [ "$create_rc" -eq 0 ] && [ "$prune_rc" -eq 0 ] && [ "$compact_rc" -eq 0 ]; then borgmatic check; check_rc=$?; else check_rc=0; fi
  if [ "$create_rc" -ne 0 ]; then exit "$create_rc"; fi
  if [ "$prune_rc" -ne 0 ]; then exit "$prune_rc"; fi
  if [ "$compact_rc" -ne 0 ]; then exit "$compact_rc"; fi
  if [ "$check_rc" -ne 0 ]; then exit "$check_rc"; fi
} > >(tee "$log") 2>&1
rc=$?
set -e
end="$(date +%s)"
duration=$((end - start))
archive="$(latest_archive)"
if [ "$rc" -eq 0 ]; then
  reachable="$(repo_reachable)"
  write_status "success" 0 "$archive" "scheduled backup completed; log=${log}" "$duration" "$reachable"
  write_prometheus "success" 0 "$duration" "$archive" "$reachable"
  publish_backup_event_and_state "success" 0 "$archive" "scheduled backup completed" "$duration"
else
  reachable="$(repo_reachable)"
  write_status "failure" "$rc" "$archive" "scheduled backup failed; log=${log}" "$duration" "$reachable"
  write_prometheus "failure" "$rc" "$duration" "$archive" "$reachable"
  publish_backup_event_and_state "failure" "$rc" "$archive" "scheduled backup failed; see Loki/Grafana hint" "$duration"
fi
exit "$rc"
SH
sed -i "s#__HOST__#${EXPECTED_HOST}#g; s#__BACKUP_USER__#${BACKUP_USER}#g; s#__TARGET_IP__#${TARGET_IP}#g; s#__REPO_PATH__#${REPO_PATH}#g" "$WRAPPER"
chmod 750 "$WRAPPER"
chown root:root "$WRAPPER"
cat > "$SERVICE" <<EOF
[Unit]
Description=Home Network Borgmatic backup for ${EXPECTED_HOST}
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=${WRAPPER}
EOF
cat > "$TIMER" <<EOF
[Unit]
Description=Daily Home Network Borgmatic backup for ${EXPECTED_HOST}

[Timer]
OnCalendar=*-*-* 03:00:00
RandomizedDelaySec=30m
Persistent=true

[Install]
WantedBy=timers.target
EOF
systemctl daemon-reload
if systemctl is-enabled --quiet borgmatic.timer 2>/dev/null || systemctl is-active --quiet borgmatic.timer 2>/dev/null; then
  systemctl disable --now borgmatic.timer
fi
systemctl enable --now "home-network-borgmatic-${EXPECTED_HOST}.timer"
systemctl list-timers "*borgmatic*" --all --no-pager
echo "good: managed backup timer enabled for ${EXPECTED_HOST}"
""",
"stage-09-status-summary.sh": r'''
echo "Status JSON: $STATUS_FILE"
if [ -f "$STATUS_FILE" ]; then
  python3 -m json.tool "$STATUS_FILE"
else
  echo "missing status file"
  exit 1
fi
read -r status exit_code duration archive reachable <<EOF
$(python3 - "$STATUS_FILE" <<'PY'
import json, sys
data=json.load(open(sys.argv[1], encoding='utf-8'))
print(data.get('status','unknown'), data.get('exit_code', 1), data.get('duration_seconds', 0), data.get('archive_name') or "__none__", 1 if data.get('repository_reachable') else 0)
PY
)
EOF
[ "$archive" = "__none__" ] && archive=""
write_prometheus "$status" "$exit_code" "$duration" "$archive" "$reachable"
''',
}


def validate_host_name(host: str) -> None:
    if not SAFE_HOST_RE.fullmatch(host):
        raise ValueError(f"invalid host name {host!r}; use DNS-safe letters, numbers, and dashes")


def validate_user(value: str, field: str) -> None:
    if not SAFE_USER_RE.fullmatch(value):
        raise ValueError(f"invalid {field} {value!r}; use a safe local SSH username")


def validate_target(value: str, field: str) -> None:
    if not SAFE_TARGET_RE.fullmatch(value):
        raise ValueError(f"invalid {field} {value!r}; use a LAN IP or DNS-safe host name")


def validate_absolute_path(value: str, field: str) -> None:
    if not value.startswith("/"):
        raise ValueError(f"{field} must be absolute: {value}")
    if not SAFE_ABSOLUTE_PATH_RE.fullmatch(value):
        raise ValueError(
            f"{field} contains unsafe characters: {value!r}; "
            "allowed characters are letters, numbers, '/', '.', '_', '+', '@', ':', and '-'"
        )


def validate_loki_url(value: str, field: str) -> None:
    if not SAFE_LOKI_URL_RE.fullmatch(value):
        raise ValueError(
            f"invalid {field} {value!r}; expected http(s)://host[:port]/loki/api/v1/push"
        )


def validate_mqtt_host(value: str, field: str) -> None:
    if not SAFE_MQTT_HOST_RE.fullmatch(value):
        raise ValueError(f"invalid {field} {value!r}; use a DNS-safe host name or LAN IP")


def validate_mqtt_port(value: int, field: str) -> None:
    if not 1 <= value <= 65535:
        raise ValueError(f"invalid {field} {value!r}; expected TCP port 1-65535")


def validate_mqtt_topic_prefix(value: str, field: str) -> None:
    if not SAFE_MQTT_TOPIC_PREFIX_RE.fullmatch(value):
        raise ValueError(f"invalid {field} {value!r}; use letters, numbers, underscores, hyphens, and slashes")


def validate_label_key(value: str, field: str) -> None:
    if not SAFE_LABEL_KEY_RE.fullmatch(value):
        raise ValueError(f"invalid {field} label key {value!r}; use letters, numbers, and underscores")


def validate_label_value(value: str, field: str) -> None:
    if not SAFE_LABEL_VALUE_RE.fullmatch(value):
        raise ValueError(
            f"invalid {field} label value {value!r}; keep labels low-cardinality and YAML-safe"
        )


def shell_single_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def load_inventory(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as f:
        data = yaml.safe_load(f) or {}
    if not isinstance(data, dict):
        raise ValueError(f"inventory root must be a mapping: {path}")
    return data


def enabled_hosts(inventory: dict[str, Any]) -> tuple[dict[str, dict[str, Any]], list[str]]:
    hosts = inventory.get("hosts") or {}
    if not isinstance(hosts, dict):
        raise ValueError("inventory.backups.yml hosts must be a mapping")
    selected: dict[str, dict[str, Any]] = {}
    warnings: list[str] = []
    for host, cfg in sorted(hosts.items()):
        host_name = str(host)
        try:
            validate_host_name(host_name)
        except ValueError as exc:
            warnings.append(f"skipping {host}: {exc}")
            continue
        if not isinstance(cfg, dict):
            warnings.append(f"skipping {host}: host config is not a mapping")
            continue
        if not cfg.get("borg_enabled", False):
            continue
        repo_path = cfg.get("repository_path")
        if not repo_path:
            warnings.append(f"skipping {host}: borg_enabled=true but repository_path is missing")
            continue
        try:
            validate_absolute_path(str(repo_path), f"hosts.{host}.repository_path")
        except ValueError as exc:
            warnings.append(f"skipping {host}: {exc}")
            continue
        selected[host_name] = cfg
    return selected, warnings


def source_paths(host: str, cfg: dict[str, Any]) -> list[str]:
    raw_paths = cfg.get("important_paths") or ["/opt/docker"]
    if not isinstance(raw_paths, list):
        raise ValueError(f"hosts.{host}.important_paths must be a list")
    paths: list[str] = []
    for item in raw_paths:
        path = str(item)
        validate_absolute_path(path, f"hosts.{host}.important_paths")
        if path not in paths:
            paths.append(path)
    if "/opt/docker" in paths:
        paths = ["/opt/docker"] + [p for p in paths if p != "/opt/docker"]
    return paths


def render_header(host: str, repo_path: str, backup_user: str, target_ip: str, inventory: dict[str, Any]) -> str:
    return (
        HEADER.replace("__HOST__", host)
        .replace("__REPO_PATH__", repo_path)
        .replace("__BACKUP_USER__", backup_user)
        .replace("__TARGET_IP__", target_ip)
        .replace("__BORGMATIC_MQTT_VARS__", borgmatic_mqtt_shell(inventory, host))
    )


def restore_candidates(paths: list[str], host: str) -> list[str]:
    candidates = [f"/opt/docker/hosts/{host}.yaml", "/opt/docker/docker-compose.yml", "/opt/docker/.home-network-backup-sentinel"]
    for path in paths:
        if path.endswith("/repo"):
            candidates.append(f"{path}/home-network/README.md")
        candidates.append(path)
    unique: list[str] = []
    for candidate in candidates:
        if candidate not in unique:
            unique.append(candidate)
    return unique


def loki_monitoring_yaml(inventory: dict[str, Any], host: str) -> str:
    cfg = inventory.get("borgmatic_loki") or {}
    if not isinstance(cfg, dict):
        raise ValueError("borgmatic_loki must be a mapping when present")

    raw_enabled_hosts = cfg.get("enabled_hosts") or []
    if not isinstance(raw_enabled_hosts, list):
        raise ValueError("borgmatic_loki.enabled_hosts must be a list")

    enabled_hosts = [str(item) for item in raw_enabled_hosts]
    for enabled_host in enabled_hosts:
        validate_host_name(enabled_host)

    if host not in enabled_hosts:
        return ""

    url = str(cfg.get("url") or "")
    if not url:
        raise ValueError("borgmatic_loki.url is required when host is enabled")
    validate_loki_url(url, "borgmatic_loki.url")

    labels = {
        "backup_profile": "default",
        "environment": "home-network",
        "host": host,
        "instance": host,
        "job": "borgmatic",
    }
    raw_labels = cfg.get("labels") or {}
    if not isinstance(raw_labels, dict):
        raise ValueError("borgmatic_loki.labels must be a mapping when present")
    for key, value in raw_labels.items():
        label_key = str(key)
        label_value = str(value)
        validate_label_key(label_key, "borgmatic_loki.labels")
        validate_label_value(label_value, f"borgmatic_loki.labels.{label_key}")
        labels[label_key] = label_value

    # Force host identity labels to inventory host names for stable, low-cardinality queries.
    labels["host"] = host
    labels["instance"] = host
    labels["job"] = labels.get("job", "borgmatic")

    label_lines = "".join(f"    {key}: {json.dumps(value)}\n" for key, value in sorted(labels.items()))
    return f"""loki:
  url: {json.dumps(url)}
  labels:
{label_lines}
"""


def borgmatic_mqtt_shell(inventory: dict[str, Any], host: str) -> str:
    cfg = inventory.get("borgmatic_mqtt") or {}
    if not isinstance(cfg, dict):
        raise ValueError("borgmatic_mqtt must be a mapping when present")

    raw_enabled_hosts = cfg.get("enabled_hosts") or []
    if not isinstance(raw_enabled_hosts, list):
        raise ValueError("borgmatic_mqtt.enabled_hosts must be a list")

    enabled_hosts = [str(item) for item in raw_enabled_hosts]
    for enabled_host in enabled_hosts:
        validate_host_name(enabled_host)

    enabled = host in enabled_hosts
    broker_host = str(cfg.get("broker_host") or "jellyhome")
    broker_port = int(cfg.get("broker_port") or 1883)
    topic_prefix = str(cfg.get("topic_prefix") or "home-network")
    retain_state = bool(cfg.get("retain_state", True))
    username = str(cfg.get("username") or "")
    password_file = str(cfg.get("password_file") or "")

    validate_mqtt_host(broker_host, "borgmatic_mqtt.broker_host")
    validate_mqtt_port(broker_port, "borgmatic_mqtt.broker_port")
    validate_mqtt_topic_prefix(topic_prefix, "borgmatic_mqtt.topic_prefix")
    if username:
        validate_user(username, "borgmatic_mqtt.username")
    if password_file:
        validate_absolute_path(password_file, "borgmatic_mqtt.password_file")

    values = {
        "MQTT_EVENTS_ENABLED": "1" if enabled else "0",
        "MQTT_BROKER_HOST": broker_host,
        "MQTT_BROKER_PORT": str(broker_port),
        "MQTT_TOPIC_PREFIX": topic_prefix.rstrip("/"),
        "MQTT_RETAIN_STATE": "1" if retain_state else "0",
        "MQTT_USERNAME": username,
        "MQTT_PASSWORD_FILE": password_file,
    }
    return "\n".join(f"{key}={shell_single_quote(value)}" for key, value in values.items())


def render_stage(content: str, paths: list[str], host: str, inventory: dict[str, Any]) -> str:
    if "__SOURCE_DIRECTORIES__" in content:
        source_yaml = "".join(f"  - {p}\n" for p in paths)
        content = content.replace("__SOURCE_DIRECTORIES__", source_yaml)
    if "__SOURCE_PREFLIGHT__" in content:
        checks = "".join(
            f"test -e {shell_single_quote(p)} || echo 'warning: configured source path missing: {p}'\n"
            for p in paths
        )
        content = content.replace("__SOURCE_PREFLIGHT__", checks)
    if "__RESTORE_CANDIDATES__" in content:
        candidate_text = " ".join(shell_single_quote(p) for p in restore_candidates(paths, host))
        content = content.replace("__RESTORE_CANDIDATES__", candidate_text)
    if "__LOKI_MONITORING__" in content:
        content = content.replace("__LOKI_MONITORING__", loki_monitoring_yaml(inventory, host))
    if "__BORGMATIC_MQTT_VARS__" in content:
        content = content.replace("__BORGMATIC_MQTT_VARS__", borgmatic_mqtt_shell(inventory, host))
    return content.lstrip()


def readme_text(host: str, stage_names: list[str]) -> str:
    stage_lines = "\n".join(f"  sudo ./{name}" for name in stage_names)
    return f"""Borgmatic rollout scripts for {host}

Run in order on the matching host with sudo. Each stage is deliberately separate so the operator controls when state changes happen.

{stage_lines}

Common guarded overrides:
  sudo ALLOW_OVERWRITE_BORGMATIC_CONFIG=1 ./stage-05-configure-borgmatic.sh
  sudo BORG_RELOCATED_REPO_ACCESS_IS_OK=yes ./stage-06-manual-backup.sh
  sudo ALLOW_OVERWRITE_MANAGED_BORGMATIC_TIMER=1 ./stage-08-enable-timer.sh
  sudo ALLOW_DISABLE_STOCK_BORGMATIC_TIMER=1 ./stage-08-enable-timer.sh

Do not paste passphrases, private keys, or exported repo keys into chat/logs.
"""


def write_host(host: str, cfg: dict[str, Any], base: Path, backup_user: str, target_ip: str, inventory: dict[str, Any]) -> None:
    repo_path = str(cfg["repository_path"])
    paths = source_paths(host, cfg)
    out = base / f"borgmatic-rollout-{host}"
    out.mkdir(parents=True, exist_ok=True)
    for name, body in STAGES.items():
        path = out / name
        text = render_header(host, repo_path, backup_user, target_ip, inventory) + render_stage(body, paths, host, inventory)
        path.write_text(text, encoding="utf-8")
        path.chmod(path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    (out / "README.txt").write_text(readme_text(host, list(STAGES)), encoding="utf-8")
    print(out)


def main() -> int:
    inventory_path = Path(os.environ.get("BORG_ROLLOUT_INVENTORY", DEFAULT_INVENTORY))
    base = Path(os.environ.get("BORG_ROLLOUT_OUTPUT_DIR", "/tmp"))
    inventory = load_inventory(inventory_path)
    primary = inventory.get("primary_target") or {}
    backup_user = str(primary.get("ssh_user") or "jellybackup")
    target_ip = str(primary.get("lan_ip") or primary.get("host") or "")
    validate_user(backup_user, "primary_target.ssh_user")
    if not target_ip:
        print("not good: primary_target.lan_ip is required", file=sys.stderr)
        return 1
    validate_target(target_ip, "primary_target.lan_ip")
    hosts, warnings = enabled_hosts(inventory)
    for warning in warnings:
        print(f"warning: {warning}", file=sys.stderr)
    if not hosts:
        print("not good: no borg_enabled hosts with repository_path found", file=sys.stderr)
        return 1
    for host, cfg in hosts.items():
        write_host(host, cfg, base, backup_user, target_ip, inventory)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except ValueError as exc:
        print(f"not good: {exc}", file=sys.stderr)
        raise SystemExit(1)
