#!/usr/bin/env bash
set -u

CHECKS=(
  "Homepage primary|http://jellyhome"
  "Dozzle|http://jellyhome:8080"
  "Portainer|https://jellyhome:9443/api/status"
  "Mosquitto MQTT|tcp://jellyhome:1883"
  "Homepage secondary|http://jellybase"
  "Home Assistant|http://jellybase:8123/manifest.json"
  "Prometheus|http://jellybase:9090/-/ready"
  "Grafana|http://jellybase:3001/api/health"
)

failures=0

printf "%-24s %s\n" "SERVICE" "STATUS"
printf "%-24s %s\n" "-------" "------"

for check in "${CHECKS[@]}"; do
  name="${check%%|*}"
  url="${check#*|}"

  if [[ "$url" == tcp://* ]]; then
    target="${url#tcp://}"
    host="${target%:*}"
    port="${target##*:}"
    if timeout 5 bash -c "</dev/tcp/${host}/${port}" >/dev/null 2>&1; then
      printf "%-24s %s\n" "$name" "good"
    else
      printf "%-24s %s\n" "$name" "not good"
      failures=$((failures + 1))
    fi
  elif curl -kfsS --max-time 5 "$url" >/dev/null 2>&1; then
    printf "%-24s %s\n" "$name" "good"
  else
    printf "%-24s %s\n" "$name" "not good"
    failures=$((failures + 1))
  fi
done

echo

if [ "$failures" -eq 0 ]; then
  echo "Overall: good"
  exit 0
else
  echo "Overall: not good"
  exit 1
fi
