#!/usr/bin/env bash
set -euo pipefail

# Create logical PostgreSQL dumps for central-postgres without printing secrets.
# Intended runtime host: jellybase.

CONTAINER="${POSTGRES_CONTAINER:-central-postgres}"
SUPERUSER="${POSTGRES_SUPERUSER:-postgres}"
DEFAULT_DB="${POSTGRES_DEFAULT_DB:-postgres}"
DUMP_BASE="${POSTGRES_DUMP_DIR:-/opt/docker/appdata/postgres/logical-dumps}"
DUMP_DATABASES="${POSTGRES_DUMP_DATABASES:-postgres manyfold}"
RETENTION_DAYS="${POSTGRES_DUMP_RETENTION_DAYS:-14}"

require_db_name() {
  case "$1" in
    ''|*[!A-Za-z0-9_]*)
      printf 'invalid database name: %s\n' "$1" >&2
      exit 2
      ;;
  esac
}

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  printf 'container not found: %s\n' "$CONTAINER" >&2
  exit 1
fi

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
tmp_dir="${DUMP_BASE}/.tmp-${timestamp}"
dest_dir="${DUMP_BASE}/${timestamp}"
umask 077
mkdir -p "$tmp_dir"
trap 'rm -rf "$tmp_dir"' EXIT

docker exec "$CONTAINER" pg_isready -U "$SUPERUSER" -d "$DEFAULT_DB" >/dev/null

docker exec "$CONTAINER" pg_dumpall --globals-only -U "$SUPERUSER" > "${tmp_dir}/globals.sql"

{
  printf 'timestamp=%s\n' "$timestamp"
  printf 'container=%s\n' "$CONTAINER"
  printf 'globals=globals.sql\n'
} > "${tmp_dir}/manifest.txt"

for db in $DUMP_DATABASES; do
  require_db_name "$db"
  exists="$(docker exec "$CONTAINER" psql -U "$SUPERUSER" -d "$DEFAULT_DB" -Atc "SELECT 1 FROM pg_database WHERE datname='${db}'" || true)"
  if [ "$exists" != "1" ]; then
    printf 'skip missing database: %s\n' "$db" | tee -a "${tmp_dir}/manifest.txt"
    continue
  fi
  docker exec "$CONTAINER" pg_dump -U "$SUPERUSER" -d "$db" -Fc > "${tmp_dir}/${db}.dump"
  printf 'database=%s file=%s.dump format=custom\n' "$db" "$db" >> "${tmp_dir}/manifest.txt"
done

mv "$tmp_dir" "$dest_dir"
trap - EXIT
ln -sfn "$(basename "$dest_dir")" "${DUMP_BASE}/latest"

if [ "$RETENTION_DAYS" -gt 0 ] 2>/dev/null; then
  find "$DUMP_BASE" -mindepth 1 -maxdepth 1 -type d -name '20??????????????Z' -mtime +"$RETENTION_DAYS" -print -exec rm -rf {} +
fi

printf 'logical dump complete: %s\n' "$dest_dir"
