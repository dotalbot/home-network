#!/usr/bin/env bash
set -euo pipefail

# Idempotently create/update the Manyfold database and service role.
# Reads the svc_manyfold password from a root/dockerops-controlled secret file.
# Does not print the password.

CONTAINER="${POSTGRES_CONTAINER:-central-postgres}"
SUPERUSER="${POSTGRES_SUPERUSER:-postgres}"
DEFAULT_DB="${POSTGRES_DEFAULT_DB:-postgres}"
APP_DB="${MANYFOLD_DB:-manyfold}"
APP_USER="${MANYFOLD_DB_USER:-svc_manyfold}"
PASSWORD_FILE="${MANYFOLD_PASSWORD_FILE:-/opt/docker/.secrets/postgres_manyfold_password}"

require_name() {
  case "$1" in
    ''|*[!A-Za-z0-9_]*)
      printf 'invalid SQL identifier: %s\n' "$1" >&2
      exit 2
      ;;
  esac
}

require_name "$APP_DB"
require_name "$APP_USER"

if [ ! -r "$PASSWORD_FILE" ]; then
  printf 'password file missing or unreadable: %s\n' "$PASSWORD_FILE" >&2
  exit 1
fi

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  printf 'container not found: %s\n' "$CONTAINER" >&2
  exit 1
fi

if [ ! -s "$PASSWORD_FILE" ]; then
  printf 'password file is empty: %s\n' "$PASSWORD_FILE" >&2
  exit 1
fi

sql="$(python3 - "$APP_DB" "$APP_USER" "$PASSWORD_FILE" <<'PY'
import pathlib, sys
app_db, app_user, password_file = sys.argv[1:4]
pw = pathlib.Path(password_file).read_text().strip().replace("'", "''")
print(f"""
DO $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '{app_user}') THEN
    CREATE ROLE {app_user} LOGIN PASSWORD '{pw}';
  ELSE
    ALTER ROLE {app_user} LOGIN PASSWORD '{pw}';
  END IF;
END
$$;

SELECT 'CREATE DATABASE {app_db} OWNER {app_user}'
WHERE NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = '{app_db}')\gexec

ALTER DATABASE {app_db} OWNER TO {app_user};
\\connect {app_db}
REVOKE CREATE ON SCHEMA public FROM PUBLIC;
GRANT USAGE, CREATE ON SCHEMA public TO {app_user};
""")
PY
)"

printf '%s\n' "$sql" | docker exec -i "$CONTAINER" psql -v ON_ERROR_STOP=1 -U "$SUPERUSER" -d "$DEFAULT_DB" >/dev/null

is_superuser="$(docker exec "$CONTAINER" psql -U "$SUPERUSER" -d "$DEFAULT_DB" -Atc "SELECT rolsuper FROM pg_roles WHERE rolname='${APP_USER}'")"
if [ "$is_superuser" != "f" ]; then
  printf 'unexpected superuser status for %s: %s\n' "$APP_USER" "$is_superuser" >&2
  exit 1
fi

printf 'database/user ready: %s / %s\n' "$APP_DB" "$APP_USER"
