TZ=Europe/London

PORTAINER_AGENT_SECRET=replace-me

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me

POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_DEFAULT_DB=postgres

# Space-separated database list for scripts/postgres-logical-dump. Missing DBs are skipped.
POSTGRES_DUMP_DATABASES=postgres manyfold
# Manyfold on jellyhome
MANYFOLD_BIND_IP=192.168.1.1
MANYFOLD_PORT=3214
MANYFOLD_PUID=1000
MANYFOLD_PGID=1000
