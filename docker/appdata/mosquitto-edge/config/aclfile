# ACL for jellydisp edge MQTT broker.
# Users are created by scripts/bootstrap-jellydisp-meross-spoke.

user ha-spoke
topic readwrite homelab/power/#
topic readwrite ha-spoke/status/#
topic readwrite homeassistant/#
topic readwrite zigbee2mqtt/#

user zigbee2mqtt
topic readwrite zigbee2mqtt/#
topic readwrite homeassistant/#

user main-ha
topic read homelab/power/#
topic read ha-spoke/status/#
topic read homeassistant/#
topic read zigbee2mqtt/#
topic write homeassistant/status
topic write zigbee2mqtt/+/set
topic write zigbee2mqtt/bridge/request/#

user edge-logger
topic read homelab/power/#
topic read zigbee2mqtt/#
